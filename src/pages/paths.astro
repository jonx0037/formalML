---
import BaseLayout from '../layouts/BaseLayout.astro';
import CurriculumGraph from '../components/viz/CurriculumGraph.tsx';
import { getCollection } from 'astro:content';
import { tracks } from '../data/curriculum';
import graphData from '../data/curriculum-graph.json';

const allTopics = await getCollection('topics');
const publishedTopics = allTopics.filter((t) => t.data.status === 'published');

// Group published topics by domain
const publishedByDomain = publishedTopics.reduce<Record<string, typeof publishedTopics>>(
  (acc, t) => {
    if (!acc[t.data.domain]) acc[t.data.domain] = [];
    acc[t.data.domain].push(t);
    return acc;
  },
  {}
);

const difficultyOrder = { foundational: 0, intermediate: 1, advanced: 2 };

const difficultyLabel: Record<string, string> = {
  foundational: 'Foundational',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};
---

<BaseLayout title="Curriculum Roadmap" description="A planned roadmap of all content areas on formalML">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-semibold font-[family-name:var(--font-sans)] mb-2">Curriculum Roadmap</h1>
    <p class="text-[var(--color-text-secondary)] mb-10 max-w-xl leading-relaxed">
      A planned map of content areas. Published topics are linked; everything else is on the roadmap.
    </p>

    {/* Interactive prerequisite graph — hidden on mobile */}
    <div class="hidden md:block mb-12">
      <p class="text-sm text-[var(--color-text-secondary)] mb-4">
        Explore the full dependency graph, or browse by track below.
      </p>
      <CurriculumGraph client:visible nodes={graphData.nodes} edges={graphData.edges} />
    </div>

    <div class="space-y-10">
      {tracks.map(({ domain, label, description, planned }) => {
        const live = (publishedByDomain[domain] ?? []).sort(
          (a, b) => difficultyOrder[a.data.difficulty] - difficultyOrder[b.data.difficulty]
        );
        const isTrackComplete = planned.length === 0 && live.length > 0;

        return (
          <div id={domain} class="border-t border-[var(--color-border)] pt-8 scroll-mt-24">
            <div class="flex items-baseline gap-3 mb-1">
              <h2 class="text-lg font-semibold font-[family-name:var(--font-sans)]">{label}</h2>
              {isTrackComplete ? (
                <span class="text-xs font-medium font-[family-name:var(--font-sans)] px-2 py-0.5 rounded-full bg-[var(--color-badge-green-bg)] text-[var(--color-badge-green-text)]">
                  Track complete
                </span>
              ) : live.length > 0 && (
                <span class="text-xs font-[family-name:var(--font-sans)] text-[var(--color-accent)]">
                  {live.length} published
                </span>
              )}
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] mb-4 leading-relaxed">{description}</p>

            <ul class="space-y-2">
              {live.map((t) => (
                <li class="flex items-center gap-3">
                  <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] flex-shrink-0" />
                  <a
                    href={`/topics/${t.id}`}
                    class="text-sm font-medium hover:text-[var(--color-accent)] transition-colors"
                  >
                    {t.data.title}
                  </a>
                  <span class="text-xs text-[var(--color-text-secondary)] capitalize">
                    {difficultyLabel[t.data.difficulty]}
                  </span>
                  {t.data.prerequisites.length === 0 && (
                    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
                      Start here
                    </span>
                  )}
                </li>
              ))}

              {planned.map((title) => (
                <li class="flex items-center gap-3 opacity-40">
                  <span class="h-1.5 w-1.5 rounded-full border border-current flex-shrink-0" />
                  <span class="text-sm">{title}</span>
                  <span class="text-xs text-[var(--color-text-secondary)]">Planned</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
