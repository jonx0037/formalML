---
interface Props {
  href: string;
  site: 'formalcalculus' | 'formalstatistics';
  topic: string;
}

const { href, site, topic } = Astro.props;

const badgeClass = `${site}-badge`;
const label = site === 'formalcalculus' ? 'formalCalculus' : 'formalStatistics';
---

<a href={href} class={badgeClass} target="_blank" rel="noopener noreferrer">
  {label}: {topic}
</a>
